rules_version = '2';

// Toutes les opérations passent par les routes API serveur (qui utilisent
// la clé Admin SDK et bypass ces règles). Les clients ne doivent pas accéder
// directement à Firestore — on bloque tout par défaut.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
